# ===========================================
# TradieMate Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Supabase ---
# Get these from: https://app.supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id
# Backend only - DO NOT expose in frontend (no VITE_ prefix)
# Get from: https://app.supabase.com -> Settings -> API -> Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Get from: https://app.supabase.com -> Account -> Access Tokens
SUPABASE_ACCESS_TOKEN=your-access-token

# --- Stripe ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secrets (from https://dashboard.stripe.com/webhooks)
# Webhook #1: Connect accounts (invoice payments)
# URL: https://your-project.supabase.co/functions/v1/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook #2: Platform account (subscriptions)
# URL: https://your-project.supabase.co/functions/v1/subscription-webhook
STRIPE_WEBHOOK_SECRET_PLATFORM=whsec_...

# Stripe Price IDs (from Products in Stripe Dashboard)
# Frontend (VITE_ prefix - visible to client, used for checkout UI):
# Monthly: Solo $29/mo, Crew $49/mo, Pro $79/mo
VITE_STRIPE_PRICE_ID_SOLO=price_xxxxx
VITE_STRIPE_PRICE_ID_CREW=price_xxxxx
VITE_STRIPE_PRICE_ID_PRO=price_xxxxx
# Annual: Solo $288/yr, Crew $468/yr, Pro $780/yr
VITE_STRIPE_PRICE_ID_SOLO_ANNUAL=price_xxxxx
VITE_STRIPE_PRICE_ID_CREW_ANNUAL=price_xxxxx
VITE_STRIPE_PRICE_ID_PRO_ANNUAL=price_xxxxx

# Backend (Edge Functions only - same IDs, no VITE_ prefix):
STRIPE_PRICE_ID_SOLO=price_xxxxx
STRIPE_PRICE_ID_CREW=price_xxxxx
STRIPE_PRICE_ID_PRO=price_xxxxx
STRIPE_PRICE_ID_SOLO_ANNUAL=price_xxxxx
STRIPE_PRICE_ID_CREW_ANNUAL=price_xxxxx
STRIPE_PRICE_ID_PRO_ANNUAL=price_xxxxx

# --- RevenueCat ---
# Get these from: https://app.revenuecat.com > App Settings
# IMPORTANT: Use PUBLIC keys, NOT secret keys (sk_)
# Android: starts with goog_
VITE_REVENUECAT_ANDROID_API_KEY=goog_your-android-key
# iOS: starts with appl_
VITE_REVENUECAT_IOS_API_KEY=appl_your-ios-key
# Web Billing: starts with rcb_
VITE_REVENUECAT_WEB_API_KEY=rcb_your-web-billing-key
# Webhook secret from: https://app.revenuecat.com/webhooks
# Webhook URL: https://your-project.supabase.co/functions/v1/revenuecat-webhook
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# --- Email (Resend) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verify your domain in Resend for production emails
# Format: "Business Name <noreply@yourdomain.com>"
EMAIL_FROM_DOMAIN="TradieMate <noreply@tradiemate.com.au>"

# --- SMS (Twilio) ---
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Xero OAuth (Optional) ---
# Get from: https://developer.xero.com/app/manage
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=https://app.tradiemate.com.au/settings/integrations?xero=success

# --- QuickBooks OAuth (Optional) ---
# Get from: https://developer.intuit.com/app/developer/dashboard
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://app.tradiemate.com.au/settings/integrations?quickbooks=success
# Set to "sandbox" for testing, "production" for live
QUICKBOOKS_ENVIRONMENT=sandbox

# --- Encryption ---
# Used for encrypting OAuth tokens at rest
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-char-random-key

# --- AI / Voice Commands ---
# Get from: https://openrouter.ai/keys
# Used by process-voice-command edge function
OPENROUTER_API_KEY=sk-or-v1-...

# --- Application Settings ---
# Production URL for redirects and webhooks
APP_URL=https://app.tradiemate.com.au

# --- Vercel ---
# Deployment token for CI/CD
VERCEL_TOKEN=
